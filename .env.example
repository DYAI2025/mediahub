# S3-Compatible Storage
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_BUCKET=dyai-media
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# Public URL base for served files
# e.g. https://medien.dyai.cloud or https://pub-xxx.r2.dev
PUBLIC_BASE_URL=https://medien.dyai.cloud

# Admin Auth (simple shared secret for v1)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: Session secret for cookie signing
SESSION_SECRET=change-me-random-32-chars-minimum

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=30
